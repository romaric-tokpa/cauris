# Cauris — variables d'environnement (placeholders).
# Copier en `.env` et renseigner. Le `.env` réel n'est JAMAIS versionné.

# --- Base de données (Turso / libSQL) ---
# En dev, laisser vide : le client retombe sur un fichier SQLite local (file:local.db).
# En prod, renseigner l'URL Turso + le token d'auth.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Auth (Better Auth) — utilisé à partir de la Phase 2 ---
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:8787

# --- IA (API Anthropic, côté serveur uniquement) — utilisé en Phase 12 ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
